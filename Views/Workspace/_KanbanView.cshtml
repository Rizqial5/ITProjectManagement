<div class="d-flex" style="gap: 24px">
    <div style="flex: 1;">
        <ejs-kanban id="KanbanBoard"
                    keyField="status"                    
                    cardSettings="@(new Syncfusion.EJ2.Kanban.KanbanCardSettings { ContentField = "title", HeaderField = "id" })"
                    >
            <e-kanban-columns>
                <e-kanban-column headerText="To Do" keyField="ToDo"></e-kanban-column>
                <e-kanban-column headerText="In Progress" keyField="InProgress"></e-kanban-column>
                <e-kanban-column headerText="Done" keyField="Done"></e-kanban-column>
            </e-kanban-columns>
        </ejs-kanban>
    </div>
    <div style="width: 320px;">
        <div class="card shadow-sm" style="height: 600px; overflow-y: auto;">
            <div class="card-header bg-primary text-white">
                <strong>Unassigned Tasks</strong>
            </div>
            <ul class="list-group list-group-flush" id="unassignedTasksList">
                <li class="list-group-item text-muted">Loading...</li>
            </ul>
        </div>
    </div>
</div>


