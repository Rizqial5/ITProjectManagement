@using ProjectManagement.App.Models
@using ProjectManagement.App.Models.Enum
@model ProjectManagement.App.ViewModel.Workspace.WorkspaceViewModel
@{
    Layout = "_WorkspaceLayout";
    ViewData["Title"] = "Workspace Board";
    // Enum values for dropdown
    var statusList = Enum.GetValues(typeof(Status))
                     .Cast<Status>()
                     .Select(s => new { Value = s.ToString(), Text = s.ToString() })
                     .ToList();
    var statusListJson = System.Text.Json.JsonSerializer.Serialize(statusList);
    string repoName = ViewBag.RepoName;
}

<div class="mb-4">
    <h1 class="project-title">Workspace: @Model.ProjectName</h1>
    <p class="text-secondary">Manage tasks and GitHub synchronization for this project.</p>
</div>

<div class="board-content">
    <div id="workspaceContent">
        <!-- GitHub Connection Card -->
        <div class="card-custom mb-4" style="border-left: 4px solid var(--primary-color);">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon bg-soft-indigo" style="width: 42px; height: 42px; font-size: 1.25rem;">
                        <i class="fab fa-github"></i>
                    </div>
                    <div>
                        @if (Model.IsConnectedToGithubRepo)
                        {
                            <div class="text-secondary smaller fw-bold text-uppercase" style="letter-spacing: 0.5px;">Connected Repository</div>
                            <a href="@ViewBag.RepoUrl" target="_blank" class="fw-800 text-main text-decoration-none fs-5" style="font-weight: 800;">
                                @ViewBag.RepoName <i class="fas fa-external-link-alt ms-1 smaller opacity-50" style="font-size: 0.8rem;"></i>
                            </a>
                        }
                        else
                        {
                            <div class="text-secondary smaller fw-bold text-uppercase" style="letter-spacing: 0.5px;">GitHub Integration</div>
                            <div class="text-secondary fw-bold">Not connected to any GitHub repository</div>
                        }
                    </div>
                </div>

                <div>
                    @if (Model.IsConnectedToGithubRepo)
                    {
                        <ejs-button id="disconnectRepoButton"
                                    cssClass="e-warning px-4 py-2"
                                    content="Disconnect Repo"
                                    iconCss="fas fa-unlink"
                                    onclick="disconnectRepo()">
                        </ejs-button>
                    }
                    else
                    {
                        <ejs-button id="connectRepoButton"
                                    cssClass="e-primary px-4 py-2"
                                    content="Connect Repository"
                                    iconCss="fas fa-link"
                                    onclick="showGithubDialog()">
                        </ejs-button>
                    }
                </div>
            </div>
        </div>

        <!-- Task Grid Card -->
        <div class="card-custom">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 text-main">Task Management</h5>
            </div>

            <ejs-grid id="TaskGrid"
                      allowPaging="true"
                      allowSorting="true"
                      commandClick="onCommandClick"
                      toolbar="@(new List<string>() { "Add", "Edit", "Delete", "Update", "Cancel" })"
                      editSettings="@(new Syncfusion.EJ2.Grids.GridEditSettings { AllowAdding = true, AllowEditing = true, AllowDeleting = true, Mode = Syncfusion.EJ2.Grids.EditMode.Normal })"
                      height="450"
                      gridLines="None"
                      cssClass="e-custom-grid">
                <e-data-manager url='@Url.Action("GetTasks", "Workspace", new { projectId = Model.ProjectID })'
                                insertUrl='@Url.Action("AddTask", "Workspace")?projectId=@Model.ProjectID'
                                updateUrl='@Url.Action("UpdateTask", "Workspace")?projectId=@Model.ProjectID'
                                removeUrl='@Url.Action("DeleteTask", "Workspace")?projectId=@Model.ProjectID'
                                adaptor="UrlAdaptor"></e-data-manager>
                <e-grid-columns>
                    <e-grid-column field="Id" headerText="ID" isPrimaryKey="true" visible="false"></e-grid-column>
                    <e-grid-column field="Title" headerText="TASK TITLE" width="200" textAlign="Left" validationRules="@(new { required = true })"></e-grid-column>
                    <e-grid-column field="Description" headerText="DESCRIPTION" width="250" textAlign="Left" validationRules="@(new { required = true })"></e-grid-column>
                    <e-grid-column field="Status"
                                   headerText="STATUS"
                                   width="150"
                                   edit="@(new { create = "StatusCreate", read = "StatusRead", write = "StatusWrite", destroy = "StatusDestroy" })"
                                   editType="dropdownedit">
                    </e-grid-column>

                    <e-grid-column headerText="ACTIONS"
                                   width="120"
                                   textAlign="Center"
                                   commands="@(new List<object>
                                    {
                                        new { type = "None", buttonOption= new { content = "Details", cssClass = "e-primary e-outline" }}
                                    })">
                    </e-grid-column>
                </e-grid-columns>
            </ejs-grid>
        </div>
    </div>

    <div id="kanbanView" style="display:none;">
        <partial name="_KanbanView" model="@Model"></partial>
    </div>
</div>

<div id="githubTarget">
    <partial name="_GithubDialog"></partial>
</div>

<script>

    var statusData = @Html.Raw(statusListJson);

    var statusElem;
    var statusObj;

    function StatusCreate() {
        statusElem = document.createElement('input');
        return statusElem;
    }

    function StatusRead() {
        return statusObj.value;
    }

    function StatusDestroy() {
        if (statusObj) statusObj.destroy();
    }

    function StatusWrite(args) {
        statusObj = new ej.dropdowns.DropDownList({
            dataSource: statusData,
            fields: { value: 'Value', text: 'Text' },
            value: args.rowData && args.rowData.Status ? args.rowData.Status : null,
            placeholder: 'Select status',
            floatLabelType: 'Never'
        });
        statusObj.appendTo(statusElem);
    }


    function onTaskActionBegin(args) {
        if (args.requestType === 'save' || args.requestType === 'delete') {
            args.data.ProjectId = @Model.ProjectID
        }
        if (args.requestType === 'save') {
            if (args.action === 'add') {
                args.url = '@Url.Action("AddTask", "Workspace")?projectId=@Model.ProjectID';
            } else if (args.action === 'edit') {
                args.url = '@Url.Action("UpdateTask", "Workspace")?projectId=@Model.ProjectID';
            }
        }
        if (args.requestType === 'delete') {
            args.url = '@Url.Action("DeleteTask", "Workspace")?projectId=@Model.ProjectID';
        }
    }

    function disconnectRepo(){
        var projectId = @ViewBag.ProjectID

        $.ajax({
            url: '@Url.Action("DisconnectRepo", "Workspace")',
            type: "POST",
            data: {
                projectId: projectId ,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() // kalau pakai antiforgery
            },
            success: function (response) {
                if (response.Success) {

                    window.location.reload();
                    
                } else {
                    ejs.notifications.ToastUtility.show(response.Message, 'Error', 3000);
                }
            },
            error: function (xhr, status, error) {

                console.error(error);
                ejs.notifications.ToastUtility.show("Error when disconnect repo", 'Error', 3000);
            }
        });
    };
    

    function showGithubDialog(){
        // Tampilkan dialog
        var dialogObj = document.getElementById("githubDialog").ej2_instances[0];

        if (!dialogObj.beforeOpenSet) {
            dialogObj.beforeOpen = function () {
                var githubGrid = document.getElementById("Github")?.ej2_instances?.[0];
                if (githubGrid) githubGrid.refresh();
            };
            dialogObj.beforeOpenSet = true; // custom flag agar tidak set dua kali
        }

        dialogObj.show();

        var checkGrid = $("#Github").length > 0;

        // Cek apakah grid sudah pernah dibuat
        if (!checkGrid) {

            $("#githubGridContainer").empty()

            var grid = new ej.grids.Grid({
                id: "Github",
                dataSource: new ej.data.DataManager({
                    url: '@Url.Action("ShowGithubRepo", "GithubAuth")',
                    adaptor: new ej.data.UrlAdaptor()
                }),
                allowPaging: true,
                allowSorting: true,
                allowFiltering: true,
                height: 400,
                commandClick: onGithubGrid,
                columns: [
                    { field: "Name", headerText: "Name", width: 200 },
                    {
                        field: "Html_Url", headerText: "URL", width: 300,
                        template: '<a href="${Html_Url}">${Html_Url}</a>'
                    },
                    { field: "Description", headerText: "Description", width: 250 },
                    {
                        headerText: "Actions", width: 120, textAlign: "Center",
                        commands: [{
                            type: "Connect",
                            buttonOption: { content: "Connect", cssClass: "e-primary" }
                        }]
                    }
                ]
            });

            grid.appendTo("#githubGridContainer");
        }
    }

    function onCommandClick(args) {
        if (args.commandColumn && args.commandColumn.buttonOption.content === "Details") {
            var rowData = args.rowData;
            var taskId = rowData.Id;
            var projectId = rowData.ProjectId;
            var isConnected = '@Model.IsConnectedToGithubRepo';

            // Redirect menggunakan Url.Action
            window.location.href = `/project/${projectId}/task/${taskId}_${isConnected}`;

        }
    }
</script>

