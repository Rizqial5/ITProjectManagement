@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.Models.Enum
@using ProjectManagement.App.ViewModel.Project
@model IEnumerable<ProjectCardViewModel>

@foreach (var project in Model)
{
    var statusClass = project.Status == Status.Done ? "status-completed" : "status-inprogress";
    var statusText = project.Status == Status.Done ? "Completed" : "In Progress";

    <div class="project-card" data-title="@project.Title" data-status="@project.Status">
        <div class="flex-grow-1">
            <div class="project-card-title d-flex justify-content-between align-items-start">
                <span>@project.Title</span>
                <span class="project-card-status @statusClass">@statusText</span>
            </div>
            
            <div class="project-card-desc mt-2">@project.Description</div>
            
            <div class="project-card-progress-section mt-3">
                <div class="project-card-progress-label">
                    <span>Progress</span>
                    <span>@project.Progress%</span>
                </div>
                <ejs-progressbar id="progress_@project.Id" 
                                 type="Linear" 
                                 value="@project.Progress" 
                                 height="8px" 
                                 trackThickness="8" 
                                 progressThickness="8"
                                 cornerRadius="Round"
                                 progressColor="var(--primary-color)">
                </ejs-progressbar>
            </div>
            
            <div class="project-card-info mt-3">
                <span><i class="fas fa-tasks"></i> @project.CompletedTasks/@project.TotalTasks tasks</span>
                <span><i class="fas fa-calendar-alt"></i> @project.DueDate.ToString("MMM dd, yyyy")</span>
            </div>
            
            <div class="project-card-info">
                @if (project.IsConnected)
                {
                    <span class="text-success"><i class="fab fa-github"></i> Connected</span>
                }
                else
                {
                    <span class="text-secondary"><i class="fab fa-github"></i> Not Connected</span>
                }
            </div>
        </div>

        <div class="project-card-footer">
            <ejs-button id="view_@project.Id"
                        content="View Details"
                        cssClass="btn-view-details"
                        onclick="viewProjectDetails('@Url.Action("Details", "Projects", new { id = project.Id })')">
            </ejs-button>

            @if (!project.IsConnected)
            {
                <ejs-button id="github_@project.Id" 
                            content="Connect"
                            cssClass="btn-github-connect"
                            iconCss="fab fa-github"
                            onclick="showGithubDialog('@project.Id')">
                </ejs-button>
            }
            else
            {
                <ejs-button id="github_@project.Id" 
                            content="Disconnect"
                            cssClass="btn-github-disconnect"
                            onclick="disconnectRepo('@project.Id')">
                </ejs-button>
            }
        </div>
    </div>
}
