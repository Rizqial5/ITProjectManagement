@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.Models.Enum
@using ProjectManagement.App.ViewModel.Project
@model IEnumerable<ProjectCardViewModel>
@{
    ViewData["Title"] = "Projects";
    var statusList = Enum.GetNames<Status>().ToArray();
    var sortList = new[] { "Name", "Date" };

}




<div class="mb-4">
    <ejs-breadcrumb id="br-projects" enableNavigation="true">
        <e-breadcrumb-items>
            <e-breadcrumb-item iconCss="e-icons e-home" url="@Url.Action("Index", "Home")"></e-breadcrumb-item>
            <e-breadcrumb-item text="Projects"></e-breadcrumb-item>
        </e-breadcrumb-items>
    </ejs-breadcrumb>
</div>

<div class="project-header mb-4">
    <div class="project-toolbar">
        <div>
            <h1 class="project-title">Projects</h1>
            <p class="project-desc">Manage and track your team projects and GitHub integrations.</p>
        </div>
        <ejs-button id="btnNewProject" cssClass="e-primary px-4 py-2" content="New Project" iconCss="e-icons e-plus" onclick="createProject()"></ejs-button>
    </div>
</div>

<div class="project-searchbar card-custom px-4 py-3 mb-4" style="border-radius: 16px;">
    <div class="d-flex gap-3 align-items-center w-100 flex-wrap">
        <div style="flex: 1; min-width: 250px;" class="position-relative">
            <i class="fas fa-search position-absolute text-secondary" style="left: 12px; top: 50%; transform: translateY(-50%); z-index: 10;"></i>
            <ejs-textbox id="searchInput" placeholder="Search projects by name..." floatLabelType="Never" width="100%" cssClass="e-outline ps-4"></ejs-textbox>
        </div>
        <div style="width: 200px;">
            <ejs-dropdownlist id="statusFilter"
                              placeholder="Filter by Status"
                              floatLabelType="Never"
                              dataSource="statusList"
                              width="100%"
                              cssClass="e-outline">
            </ejs-dropdownlist>
        </div>
        <div style="width: 180px;">
            <ejs-dropdownlist id="sortFilter"
                              placeholder="Sort By"
                              floatLabelType="Never"
                              dataSource="sortList"
                              width="100%"
                              cssClass="e-outline">
            </ejs-dropdownlist>
        </div>
    </div>
</div>


<div class="project-cards-row mb-4" id="projectCardsRow">
    @await Html.PartialAsync("_ProjectCardListPartial", Model)
</div>

<div class="d-flex justify-content-center mt-5 mb-5 pb-5">
    <div class="card-custom p-2" style="border-radius: 12px; background: #fff; box-shadow: var(--shadow-sm);">
        <ejs-pager id="ProjectPager"
                   pageSize="@ViewBag.PageSize"
                   totalRecordsCount="@ViewBag.TotalRecords"
                   pageSizes="true">
        </ejs-pager>
    </div>
</div>

<partial name="_GithubDialog"></partial>
<ejs-dialog id="createProjectDialog" header="Create new Project"
            width="500px" visible="false" showCloseIcon="true" isModal="true"
            target="#dialogTarget">
    <e-content-template>
        <partial name="_CreateProjectDialog" model="new CreateProjectDto()"></partial>
    </e-content-template>
</ejs-dialog>




@section Scripts {
    <ejs-scripts></ejs-scripts>


    <script>

        document.addEventListener("DOMContentLoaded", setPagerClick)

        function setPagerClick() {

            var pager = document.getElementById("ProjectPager").ej2_instances[0];
            pager.click = onPagerClick;
        }

        function onPagerClick(args) {
            $.ajax({
                url: '@Url.Action("GetPagedProjects", "Projects")',
                type: 'POST',
                data: {
                    currentPage: args.currentPage,
                    pageSize: this.pageSize
                },
                success: function (result) {
                    $("#projectCardsRow").html(result);
                },
                error: function () {
                    console.error("Failed to load paged projects.");
                }
            });
        }

        // Real-time search & filter
        function filterProjects() {
            var search = $('#searchInput').val().toLowerCase();
            var status = $('#statusFilter').val();
            var sort = $('#sortFilter').val();
            var $cards = $('#projectCardsRow .project-card');

            $cards.each(function () {
                var $card = $(this);
                var title = $card.data('title').toLowerCase();
                var cardStatus = $card.data('status');
                var show = true;

                if (search && !title.includes(search)) show = false;
                if (status && status !== cardStatus) show = false;

                $card.toggle(show);
            });

            // Optional: sort by name or date
            if (sort === "Name") {
                $cards.sort(function (a, b) {
                    return $(a).data('title').localeCompare($(b).data('title'));
                });
            }
            // Add sort by date if needed
            $('#projectCardsRow').html($cards);
        }

        $('#searchInput').on('input', filterProjects);
        $('#statusFilter').on('change', filterProjects);
        $('#sortFilter').on('change', filterProjects);

        function viewProjectDetails(url) {
            // Implementasi navigasi ke detail project

            window.location.href = url;
        }

        function connectProject(id) {
            console.log("connecting... " + id )
        }
        

        function disconnectRepo(id,repoId) {
            showConfirmationDialog(
                "Disconnect project",
                "Are you sure you want to disconnect this project from github repo?",
                function () {
                    // YES action

                    $.ajax({
                        url: '@Url.Action("DisconnectRepo", "Workspace")',
                        type: "POST",
                        data: {
                            projectId: id
                        },
                        success: function (response) {

                            location.reload();

                        },
                        error: function (xhr, status, error) {

                            console.error(error);
                            location.reload();
                        }
                    });
                    // TODO: panggil Ajax ke controller kalau perlu
                },
                function () {
                    // NO action
                    console.log("User cancelled");
                }
            );
        }

    </script>
}

