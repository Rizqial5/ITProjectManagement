@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.DTO.Task
@using ProjectManagement.App.Extensions
@using ProjectManagement.App.Models.Enum
@using Syncfusion.EJ2
@model ProjectDetailsDto
@{
    ViewData["Title"] = "Project Details";
}

<partial name="_CreateTaskDialog" model="new CreateTaskDto() {ProjectTitle = Model.Title, ProjectID = Model.Id}"></partial>
<partial name="_AddMemberDialog" model="new AddProjectMemberDto() {ProjectId = Model.Id, ProjectTitle = Model.Title}"></partial>
<partial name="_EditMemberRoleDialog" model="new AddProjectMemberDto() {ProjectId = Model.Id}"></partial>

<div class="mb-4">
    <ejs-breadcrumb id="br-details" enableNavigation="true">
        <e-breadcrumb-items>
            <e-breadcrumb-item iconCss="e-icons e-home" url="@Url.Action("Index","Home")"></e-breadcrumb-item>
            <e-breadcrumb-item text="Projects" url="@Url.Action("Page", "Projects")"></e-breadcrumb-item>
            <e-breadcrumb-item text="@Model.Title" url=""></e-breadcrumb-item>
        </e-breadcrumb-items>
    </ejs-breadcrumb>
</div>

<div class="details-header flex-column flex-md-row align-items-center">
    <div>
        <h1 class="details-title">
            @Model.Title
            <span class="badge @(Model.Status == "Done" ? "status-completed" : "status-inprogress")">@Model.Status</span>
        </h1>
        <p class="details-desc">@Model.Description</p>
    </div>
    <div class="d-flex gap-3 mt-3 mt-md-0">
        @if (!Model.IsConnected)
        {
            <ejs-button id="connectRepo" content="Connect GitHub" cssClass="e-primary px-4 py-2" iconCss="fab fa-github" onclick="showGithubDialog('@Model.Id')"></ejs-button>
        }
        else
        {
            <ejs-button id="disconnectRepo" content="Disconnect GitHub" cssClass="e-warning px-4 py-2" iconCss="fab fa-github" onclick="disconnectRepo('@Model.Id')"></ejs-button>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Overview & Tasks -->
    <div class="col-lg-8">
        <div class="card-custom mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 text-main">Project Overview</h5>
                <div class="text-secondary smaller fw-bold text-uppercase" style="letter-spacing: 1px;">
                    <i class="fas fa-calendar-alt me-1"></i> Due @Model.DueDate.ToString("MMM dd, yyyy")
                </div>
            </div>

            <div class="project-progress-area mb-4">
                <div class="d-flex justify-content-between small fw-bold mb-2">
                    <span class="text-secondary">Overall Completion</span>
                    <span class="text-main">@Model.Progress%</span>
                </div>
                <ejs-progressbar id="project_progress" 
                                 type="Linear" 
                                 value="@Model.Progress" 
                                 height="10px" 
                                 trackThickness="10" 
                                 progressThickness="10"
                                 cornerRadius="Round"
                                 progressColor="var(--primary-color)">
                </ejs-progressbar>
            </div>

            <div class="details-stats-grid">
                <div class="stat-card">
                    <i class="fas fa-tasks text-primary"></i>
                    <div class="value">@Model.TotalTasks</div>
                    <div class="label">Tasks</div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-check-circle text-success"></i>
                    <div class="value">@Model.CompletedTasks</div>
                    <div class="label">Done</div>
                </div>
                <div class="stat-card">
                    <i class="fas fa-code-branch text-warning"></i>
                    <div class="value">@Model.TotalCommits</div>
                    <div class="label">Commits</div>
                </div>
            </div>
        </div>

        <div class="card-custom">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 text-main">Project Tasks</h5>
                <ejs-button id="addTaskButton" content="New Task" cssClass="e-primary" iconCss="e-icons e-plus" onclick="showCreateTaskDialog()"></ejs-button>
            </div>

            <div class="tasks-list-modern">
                @if (Model.Tasks.Any())
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <div class="task-item-modern" 
                             hx-get 
                             hx-action="Details" 
                             hx-controller="Task" 
                             hx-route-projectId="@Model.Id" 
                             hx-route-taskId="@task.Id" 
                             hx-route-isConnected="@Model.IsConnected" 
                             hx-target="#main-content" 
                             hx-swap="innerHTML">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="task-item-title">@task.Title</div>
                                    <div class="task-item-meta">
                                        <span><i class="fas fa-calendar-day me-1"></i> Due @task.DueDate.ToString("MMM dd")</span>
                                        @if (task.Commits > 0)
                                        {
                                            <span><i class="fas fa-code-commit me-1"></i> @task.Commits commits</span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex flex-column align-items-end gap-2">
                                    <span class="badge @(task.Priority == "High" ? "priority-high" : "priority-low")">@task.Priority</span>
                                    <span class="badge @(task.Status == "ToDo" ? "status-todo" : "status-inprogress")">@task.Status</span>
                                    @if (task.IsOverDue)
                                    {
                                        <span class="badge status-overdue">Overdue</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-secondary">
                        <i class="fas fa-clipboard-list fa-3x mb-3 opacity-25"></i>
                        <p>No tasks found for this project.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Team Members -->
    <div class="col-lg-4">
        <div class="card-custom">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0 text-main">Team Members</h5>
                @if (ViewBag.CurrentUserRole == ProjectRole.Owner)
                {
                    <button class="btn btn-primary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" onclick="showAddMemberDialog()">
                        <i class="fas fa-plus"></i>
                    </button>
                }
            </div>

            <div class="team-list-container">
                @if (!Model.Members.Any())
                {
                    <div class="text-center py-4 text-secondary smaller fw-bold">No members assigned.</div>
                }
                else
                {
                    foreach (var m in Model.Members)
                    {
                        var initials = string.Concat(m.Name.Split(' ').Select(x => x[0])).ToUpper();
                        if (initials.Length > 2) initials = initials.Substring(0, 2);

                        <div class="team-member-item">
                            <div class="member-info">
                                <div class="member-avatar">@initials</div>
                                <div>
                                    <div class="member-name">@m.Name</div>
                                    <span class="role-badge role-@m.Role.ToLower()">@m.Role</span>
                                </div>
                            </div>
                            
                            @if (m.Role != "Owner" && m.UserId != ViewBag.CurrentUserId) 
                            {
                                var canEditRole = ViewBag.CurrentUserRole == ProjectRole.Owner || 
                                                  ViewBag.CurrentUserRole == ProjectRole.Manager || 
                                                  ViewBag.CurrentUserRole == ProjectRole.TeamLead;
                                
                                var canRemoveMember = ViewBag.CurrentUserRole == ProjectRole.Owner || 
                                                      ViewBag.CurrentUserRole == ProjectRole.Manager;

                                if (canEditRole || canRemoveMember)
                                {
                                    <div class="member-actions ms-auto">
                                        @if (canEditRole)
                                        {
                                            <button class="btn btn-link text-secondary p-1" onclick="showEditRoleDialog('@m.UserId', '@m.Role')" title="Edit Role">
                                                <i class="fas fa-edit small"></i>
                                            </button>
                                        }
                                        @if (canRemoveMember)
                                        {
                                            <button class="btn btn-link text-danger p-1" onclick="removeMember('@m.UserId', '@m.Name')" title="Remove Member">
                                                <i class="fas fa-user-minus small"></i>
                                            </button>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>


<partial name="_GithubDialog"></partial>

<script>
    function disconnectRepo(projectId) {
        showConfirmationDialog(
            "Disconnect GitHub",
            "Are you sure you want to disconnect the GitHub repository from this project?",
            function () {
                $.ajax({
                    url: '@Url.Action("DisconnectRepo", "Workspace")',
                    type: "POST",
                    data: {
                        projectId: projectId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.Success) {
                            location.reload();
                        } else {
                            ejs.notifications.ToastUtility.show(response.Message || "Failed to disconnect repo.", 'Error', 3000);
                        }
                    },
                    error: function () {
                        ejs.notifications.ToastUtility.show("An error occurred while disconnecting the repository.", 'Error', 3000);
                    }
                });
            }
        );
    }

    // showGithubDialog is defined in the partial, but we might need to override/ensure it's available
    function removeMember(userId, userName) {
        showConfirmationDialog(
            "Remove Member",
            "Are you sure you want to remove " + userName + " from this project?",
            function () {
                $.ajax({
                    url: '@Url.Action("RemoveMember", "Projects")',
                    type: "POST",
                    data: {
                        projectId: '@Model.Id',
                        userId: userId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            ejs.notifications.ToastUtility.show(response.message || "Failed to remove member.", 'Error', 3000);
                        }
                    },
                    error: function () {
                        ejs.notifications.ToastUtility.show("An error occurred while removing the member.", 'Error', 3000);
                    }
                });
            }
        );
    }
</script>

@Html.EJS().ScriptManager()
