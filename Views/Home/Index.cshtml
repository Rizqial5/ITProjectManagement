                            <div class="icon-circle">
                                <i class="fas fa-folder"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div id="vertical_Sample">
                    <!-- Horizontal Card Layout for Philips Trimmer Product -->
                    <div tabindex="0" class="e-card e-card-horizontal card-tasks">
                        <div class='e-card-stacked'>
                            <div class="e-card-header-title">Total Tasks</div>
                            <h3>9</h3>
                            <div class="e-card-sub-title">3 completed</div>
                        </div>
                        <div>
                            <div class="icon-circle">
                                <i class="fas fa-check-square"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div id="vertical_Sample">
                    <!-- Horizontal Card Layout for Philips Trimmer Product -->
                    <div tabindex="0" class="e-card e-card-horizontal card-team">
                        <div class='e-card-stacked'>
                            <div class="e-card-header-title">Team Members</div>
                            <h3>4</h3>
                            <div class="e-card-sub-title">Active contributors</div>
                        </div>
                        <div>
                            <div class="icon-circle">
                                <i class="fas fa-users"></i>
                            </div>
