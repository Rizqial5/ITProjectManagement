@using ProjectManagement.App.DTO.Project
@using Syncfusion.EJ2.Grids
@{
    ViewData["Title"] = "Home Page";
    
}

@model IEnumerable<Project>

<style>
.e-grid .e-rowcell.align-left {
    text-align: left !important;
}
</style>

<div class="text-center mt-5">


    @if (ViewBag.IsProjectEmpty)
    {
        <h1 class="display-4">Welcome</h1>
        <div>
            <p>Project is Empty</p>
        </div>
    }
    else
    {
        <ejs-grid id="ExistingProjectGrid"
                  dataSource="@Model"
                  allowPaging="true"
                  gridLines="Both"
                  enableHover="true"
                  allowTextWrap="true"
                  commandClick="onCommandClick"
                  height="400">
            <e-grid-columns>
                <e-grid-column field="Name"
                               headerText="Project Name"
                               width="200"
                               textAlign="Left"
                               customAttributes="@(new { @class = "align-left" })">
                </e-grid-column>

                <e-grid-column field="Description"
                               headerText="Description"
                               width="300"
                               textAlign="Left"
                               customAttributes="@(new { @class = "align-left" })">
                </e-grid-column>

                <e-grid-column headerText="Actions"
                               width="120"
                               textAlign="Center"
                               commands="@(new List<object>
                                          {
                                            new { type = "None", buttonOption= new { content = "View", cssClass = "e-primary" }}
                                          })">
                </e-grid-column>
            </e-grid-columns>
        </ejs-grid>
    }
    <ejs-toast id="toast_default"></ejs-toast>

    <ejs-button id="createButton" class="mt-3" isPrimary="true" content="Create a Project" onclick="createProject()"></ejs-button>
</div>



<div id="dialogTarget" >
    <ejs-dialog id="createProjectDialog" header="Create new Project"
                width="500px" visible="false" showCloseIcon="true" isModal="true"
                target="#dialogTarget">
        <e-content-template>
            <partial name="_CreateProjectDialog" model="new CreateProjectDto()"></partial>
        </e-content-template>
    </ejs-dialog>
</div>







<script>

    function createProject() {
        var dialog = document.getElementById("createProjectDialog").ej2_instances[0];
        dialog.show();
    }


    function onCommandClick(args) {
        const row = args.rowData;
        const id = row.Id; // pastikan model punya property "Id"
        
        console.log("View")
    }



    
    $('#createForm').on('submit', function (e) {
        e.preventDefault();

        var form = $(this);



        var formData = form.serialize();



        $.ajax({
            type: 'POST',
            url: form.attr('action'),
            data: formData,
            success: function (response, status, xhr) {
                if (response.success == false) {
                    // Gagal validasi, return PartialView ulang
                    $("#createForm").validate().showErrors();


                } else {
                    // Sukses, tutup dialog & reload halaman
                    ejs.notifications.ToastUtility.show('Your message has been sent successfully', 'Success', 20000);
                    var dialog = $('#createProjectDialog')[0].ej2_instances[0];
                    dialog.hide();
                    location.reload();
                }
            },
            error: function () {
                alert("Terjadi kesalahan saat menyimpan.");
            }
        });
    });
     
     

    
</script>
