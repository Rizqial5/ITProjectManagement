@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.ViewModel.Home
@using Syncfusion.EJ2.Grids
@{
    ViewData["Title"] = "Home Page";

   

}

@model IEnumerable<ProjectViewModel>

<style>

