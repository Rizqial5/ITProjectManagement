        flex: 5;
    }

    .icon-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
    }

    /* Tema Warna */
    .card-projects {
        background-color: #eaf2ff;
    }

        .card-projects .icon-circle {
            background-color: #3b82f6;
        }

    .card-tasks {
        background-color: #fff4e6;
    }

        .card-tasks .icon-circle {
            background-color: #f97316;
        }

    .card-team {
        background-color: #e6fff4;
    }

