@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="mb-4">
    <h1 class="project-title">@ViewData["Title"]</h1>
    <p class="text-secondary">Last updated: May 2024</p>
</div>

<div class="card-custom">
    <h5 class="fw-bold text-main mb-3">Our Commitment to Privacy</h5>
    <p class="text-secondary" style="line-height: 1.6;">
        Use this page to detail your site's privacy policy. We value your data security and transparency.
        This application integrates with GitHub and stores minimal information necessary for project management.
    </p>
    
    <hr class="my-4" style="border-color: var(--border-color);" />
    
    <h5 class="fw-bold text-main mb-3">Data Collection</h5>
    <p class="text-secondary" style="line-height: 1.6;">
        We collect project metadata, task details, and GitHub repository links to provide you with a seamless management experience.
        Your GitHub access tokens are encrypted and protected using industry standards.
    </p>
</div>
