@using Syncfusion.EJ2
@using Syncfusion.EJ2.Navigations
@using Syncfusion.EJ2.ProgressBar
@using Syncfusion.EJ2.Buttons
@using ProjectManagement.App.Extensions
@model ProjectManagement.App.ViewModel.TaskViewModel

@{
    var isOverdue = Model.DueDate < DateTime.Now && Model.Status != "Done";
    var completion = Model.Completion ?? 0; 
    var priority = Model.Priority ?? "Low";
    var diffDate = (Model.DueDate - DateTime.Now).Days;
}

<div class="task-details-container">
    <div class="mb-4">
        <ejs-breadcrumb id="br-tasks" enableNavigation="true">
            <e-breadcrumb-items>
                <e-breadcrumb-item iconCss="e-icons e-home" url="@Url.Action("Index", "Home")"></e-breadcrumb-item>
                <e-breadcrumb-item text="Projects" url="@Url.Action("Page", "Projects")"></e-breadcrumb-item>
                <e-breadcrumb-item text="@Model.ProjectName" hx-get="@Url.Action("Details", "Projects", new { id = Model.ProjectId })" hx-target="#main-content"></e-breadcrumb-item>
                <e-breadcrumb-item text="@Model.Title"></e-breadcrumb-item>
            </e-breadcrumb-items>
        </ejs-breadcrumb>
    </div>

    <!-- Header -->
    <div class="task-details-header d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="task-details-title">@Model.Title</h1>
            <div class="task-details-meta">
                <span class="text-primary fw-bold">@Model.ProjectName</span>
                <span class="text-light">|</span>
                <span class="@(isOverdue ? "text-danger fw-bold" : "text-secondary")">
                    <i class="fas fa-calendar-alt me-1"></i> Due @Model.DueDate.ToString("MMM dd, yyyy")
                </span>
                @if (isOverdue)
                {
                    <span class="soft-badge bg-soft-danger ms-1">Overdue</span>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
            <span class="badge @(priority == "High" ? "priority-high" : "priority-low")">@priority Priority</span>
            <span class="badge @(Model.Status == "ToDo" ? "status-todo" : "status-inprogress")">@Model.Status</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-8">
            <div class="mb-4">
                <partial name="_TaskDescPanel" model="Model" />
            </div>

            <div class="card-custom">
                <h5 class="fw-bold mb-4 text-main">Activity & Commits</h5>
                <partial name="Component/_TabsPanelTask" model="Model"></partial>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-4">
            <!-- Progress Summary Card -->
            <div class="card-custom mb-4 shadow-sm">
                <h5 class="fw-bold mb-4 text-main">Progress Summary</h5>
                <div class="project-progress-area mb-4">
                    <div class="d-flex justify-content-between smaller fw-bold mb-2">
                        <span class="text-secondary">Completion Rate</span>
                        <span class="text-main">@completion%</span>
                    </div>
                    <ejs-progressbar id="task_progressbar" 
                                     type="Linear" 
                                     value="@completion" 
                                     height="10px" 
                                     trackThickness="10" 
                                     progressThickness="10"
                                     cornerRadius="Round"
                                     progressColor="var(--primary-color)">
                    </ejs-progressbar>
                </div>
                
                <div class="mt-4 pt-3 border-top">
                    <div class="summary-stat-row">
                        <span class="summary-label">Linked Commits</span>
                        <span class="summary-value text-primary fw-bold"><i class="fas fa-code-branch me-1"></i> @Model.TotalLinkedCommits</span>
                    </div>
                    <div class="summary-stat-row">
                        <span class="summary-label">Time Status</span>
                        <span class="summary-value @(isOverdue ? "text-danger" : "text-success") fw-bold">
                            <i class="fas fa-clock me-1"></i> 
                            @(isOverdue ? "Overdue" : (diffDate < 0 ? "Due Today" : diffDate + " days left"))
                        </span>
                    </div>
                </div>

                <div class="mt-4" id="statusTask">
                    @await Html.PartialAsync("Component/_StatusMarkButton", Model)
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card-custom shadow-sm">
                <h5 class="fw-bold mb-3 text-main">Quick Actions</h5>
                <div class="d-flex flex-column gap-1">
                    <button class="quick-action-btn"
                            hx-get
                            hx-action="ShowUpdateDialog"
                            hx-controller="Task"
                            hx-route-projectId="@Model.ProjectId"
                            hx-route-taskId="@Model.TaskId"
                            hx-target="#updateDialog">
                        <i class="fas fa-edit text-primary"></i> Update Due Date
                    </button>
                    <button class="quick-action-btn">
                        <i class="fas fa-external-link-alt text-secondary"></i> View Repository
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_LinkCommitDialog"></partial>
<div id="updateDialog"></div>

<script>
    document.body.addEventListener("htmx:afterOnLoad", function (evt) {
        if (evt.detail.target.id === "updateDialog") {
            showUpdateDateDialog();
        }
    });
</script>

@Html.EJS().ScriptManager()
