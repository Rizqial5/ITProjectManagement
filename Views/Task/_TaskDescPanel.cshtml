@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.Models.Enum
@using ProjectManagement.App.ViewModel.Project
@using Syncfusion.EJ2
@model ProjectManagement.App.ViewModel.TaskViewModel
@{
    var priority = Model.Priority ?? "Low";
    var desc = Model.Description ?? "";
    var lines = desc.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);

    bool isList =
        lines.Length > 1 &&
        lines.All(l =>
            l.TrimStart().StartsWith("-") ||
            l.TrimStart().StartsWith("*") ||
            char.IsDigit(l.TrimStart().FirstOrDefault())
        );
}

<div class="card-custom" id="detailsPanel">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <h5 class="fw-bold m-0 text-main">Task Details</h5>
        <ejs-button id="btnEditTaskDetails"
                    cssClass="e-outline d-flex align-items-center justify-content-center"
                    iconCss="fas fa-pencil-alt"
                    hx-get="@Url.Action("EditTaskDetails", "Task", new { projectId = Model.ProjectId, taskId = Model.TaskId })"
                    hx-target="#detailsPanel"
                    hx-trigger="click"
                    hx-swap="outerHTML">
        </ejs-button>
    </div>
    
    <div class="row g-4">
        <div class="col-md-7">
            <div class="mb-4">
                <div class="text-secondary smaller fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Description</div>
                <div class="text-main" style="line-height: 1.6;">
                    @if (isList)
                    {
                        <ul class="mb-0 ps-3">
                            @foreach (var line in lines)
                            {
                                var text = line.TrimStart();
                                text = text.TrimStart('-', '*').Trim();

                                if (char.IsDigit(text.FirstOrDefault()) && text.Contains("."))
                                {
                                    var idx = text.IndexOf(".");
                                    if (idx > 0) text = text.Substring(idx + 1).Trim();
                                }
                                <li class="mb-1">@text</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="m-0">@Model.Description</p>
                    }
                </div>
            </div>
            
            <div>
                <div class="text-secondary smaller fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Status</div>
                <span class="soft-badge @(Model.Status == "ToDo" ? "bg-soft-indigo" : "bg-soft-success")">@Model.Status</span>
            </div>
        </div>
        
        <div class="col-md-5">
            <div class="p-3 bg-light rounded-3" style="border: 1px solid var(--border-color);">
                <div class="mb-3">
                    <div class="text-secondary smaller fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Assignee</div>
                    <div class="d-flex align-items-center">
                        <div class="user-avatar-circle me-3" style="width: 32px; height: 32px; font-size: 0.8rem; box-shadow: none;">
                            @(Model.AssigneeName?[0].ToString().ToUpper() ?? "?")
                        </div>
                        <span class="fw-bold text-main">@(Model.AssigneeName ?? "Unassigned")</span>
                    </div>
                </div>
                
                <div class="mb-3 pt-3 border-top">
                    <div class="text-secondary smaller fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Priority</div>
                    <span class="badge @(priority == "High" ? "priority-high" : "priority-low")">@priority</span>
                </div>
                
                <div class="pt-3 border-top">
                    <div class="text-secondary smaller fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px;">Last Updated</div>
                    <div class="text-main small fw-bold">@Model.LastUpdated</div>
                </div>
            </div>
        </div>
    </div>
</div>

@if(Model.isRequestHtmx && !Model.InitPage)
{
    <div class="summary-actions" id="statusTask" hx-swap-oob='true'>
        @await Html.PartialAsync("Component/_StatusMarkButton", Model)
    </div>
}

@Html.EJS().ScriptManager()