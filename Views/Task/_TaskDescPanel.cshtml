@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.Models.Enum
@using ProjectManagement.App.ViewModel.Project
@using Syncfusion.EJ2
@model ProjectManagement.App.ViewModel.TaskViewModel
@{
    ViewData["Title"] = "Projects";
    var statusList = Enum.GetNames<Status>().ToArray();
    var sortList = new[] { "Name", "Date" };
    var priority = Model.Priority ?? "Low";

    var desc = Model.Description ?? "";
    var lines = desc.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);

    bool isList =
        lines.Length > 1 &&                              // lebih dari 1 baris
        lines.All(l =>
            l.TrimStart().StartsWith("-") ||             // contoh: "- item"
            l.TrimStart().StartsWith("*") ||             // contoh: "* item"
            char.IsDigit(l.TrimStart().FirstOrDefault()) // contoh: "1. item"
        );
}


<div class="card-custom" id="detailsPanel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold m-0">Task Details</h5>
        <ejs-button id="btnEditTaskDetails"
                    cssClass="e-outline"
                    iconCss="fas fa-pencil-alt"
                    hx-get="@Url.Action("EditTaskDetails", "Task", new { projectId = Model.ProjectId, taskId = Model.TaskId })"
                    hx-target="#detailsPanel"
                    hx-trigger="click"
                    hx-swap="outerHTML">
        </ejs-button>
    </div>
    <div class="row">
        <div class="col-md-8">
            <div class="card-section">
                <div><b>Description</b></div>
                @if (isList)
                {
                    <ul class="task-description-list">
                        @foreach (var line in lines)
                        {
                            // bersihkan prefix list seperti "-", "*", "1."
                            var text = line.TrimStart();
                            text = text.TrimStart('-', '*').Trim();

                            // menghapus numbering "1." , "2." , dst
                            if (char.IsDigit(text.FirstOrDefault()) && text.Contains("."))
                            {
                                var idx = text.IndexOf(".");
                                if (idx > 0) text = text.Substring(idx + 1).Trim();
                            }

                            <li>@text</li>
                        }
                    </ul>
                }
                else
                {
                    <div>@Model.Description</div>
                }
            </div>
            <div class="card-section">
                <div><b>Status</b></div>
                <div>@Model.Status</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-section">
                <div><b>Assignee</b></div>
                <div class="d-flex align-items-center">
                    <div class="avatar-circle me-2">@(Model.AssigneeName?[0].ToString().ToUpper() ?? "?")</div>
                    <span>@(Model.AssigneeName ?? "Unassigned")</span>
                </div>
            </div>
            <div class="card-section">
                <div><b>Priority</b></div>
                <span class="badge badge-priority-low">@priority</span>
            </div>
            <div class="card-section">
                <div><b>Last Updated</b></div>
                <div>@Model.LastUpdated</div>
            </div>
        </div>
    </div>
</div>

@if(Model.isRequestHtmx && !Model.InitPage)
{
    <div class="summary-actions" id="statusTask" hx-swap-oob='true'>
        @await Html.PartialAsync("Component/_StatusMarkButton", Model)
    </div>
}

@Html.EJS().ScriptManager()