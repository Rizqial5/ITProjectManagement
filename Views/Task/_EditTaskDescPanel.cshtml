@using Syncfusion.EJ2
@using ProjectManagement.App.DTO.Project
@using ProjectManagement.App.Models.Enum
@using ProjectManagement.App.DTO.Task
@using ProjectManagement.App.ViewModel.Project
@model EditTaskDescDto
@{
    var statusList = Enum.GetNames<Status>().ToArray();
    var sortList = new[] { "Name", "Date" };
    var priority = Model.Priority ?? "Low";
}

<form class="card-custom" id="detailsPanel" asp-action="UpdateTaskDetails" asp-controller="Task"
      hx-post="@Url.Action("UpdateTaskDetails", "Task")"
      hx-target="#detailsPanel"
      hx-swap="outerHTML"
      id="editTaskDetailsForm">
    
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <h5 class="fw-bold m-0 text-main">Edit Task Details</h5>
    </div>

    <div class="row g-4">
        <div class="col-md-7">
            <div class="mb-4">
                <label for="Description" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;">Description</label>
                <textarea asp-for="Description" class="form-control" style="border-radius: 12px; border-color: var(--border-color); background: #fcfdfe;" name="Description" rows="5">@Model.Description</textarea>
            </div>
            
            <div class="mb-3">
                <label asp-for="Status" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;">Status</label>
                <ejs-dropdownlist id="Status" dataSource="@statusList" ejs-for="Status" popupHeight="200px" cssClass="e-outline"></ejs-dropdownlist>
            </div>
        </div>
        
        <div class="col-md-5">
            <div class="p-3 bg-light rounded-3" style="border: 1px solid var(--border-color);">
                <div class="mb-4">
                    <label asp-for="AssignedUserId" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;">Assign To</label>
                    <ejs-dropdownlist id="AssignedUserId" 
                                    dataSource="@(ViewBag.AvailableAssignees)" 
                                    ejs-for="AssignedUserId" 
                                    placeholder="Select Assignee"
                                    popupHeight="200px"
                                    cssClass="e-outline">
                        <e-dropdownlist-fields text="text" value="value"></e-dropdownlist-fields>
                    </ejs-dropdownlist>
                </div>
                
                <div class="mb-3 pt-3 border-top">
                    <div class="text-secondary smaller fw-bold text-uppercase mb-2" style="letter-spacing: 0.5px;">Priority</div>
                    <span class="badge @(priority == "High" ? "priority-high" : "priority-low")">@priority</span>
                </div>
                
                <div class="pt-3 border-top">
                    <div class="text-secondary smaller fw-bold text-uppercase mb-1" style="letter-spacing: 0.5px;">Last Updated</div>
                    <div class="text-main small fw-bold">@Model.LastUpdated</div>
                </div>
            </div>
        </div>
    </div>
    
    <input type="hidden" asp-for=TaskId value="@Model.TaskId" />
    <input type="hidden" asp-for="ProjectId" value="@Model.ProjectId" />
    
    <div class="d-flex justify-content-end mt-4 pt-3 border-top gap-2">
        <button type="button" class="btn btn-light fw-bold px-4" style="border-radius: 10px; border: 1px solid var(--border-color);"
                hx-get="@Url.Action("DetailsPanel", "Task", new { projectId = Model.ProjectId, taskId = Model.TaskId })"
                hx-target="#detailsPanel"
                hx-swap="outerHTML">
            Cancel
        </button>
        <button type="submit" class="btn btn-primary fw-bold px-4" style="border-radius: 10px; background-color: var(--primary-color); border: none;">
            <i class="fas fa-save me-1"></i> Save
        </button>
    </div>
</form>
@Html.EJS().ScriptManager()