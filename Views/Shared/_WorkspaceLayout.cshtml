<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Workspace</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectManagement.App.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ej2/material.css" asp-append-version="true" />
    <script src="https://cdn.syncfusion.com/ej2/31.2.12/dist/ej2.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
</head>
<body>
    <div id="app-root">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-sm">
            <div class="container-fluid p-0 d-flex justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <button id="sidebarToggle" class="btn">
                        <i class="fas fa-bars"></i>
                    </button>
                    <a class="navbar-brand d-none d-md-block" href="@Url.Action("Index", "Home")">ProjectManagement</a>
                    <span class="text-light d-none d-md-inline mx-2">/</span>
                    <span class="fw-bold text-main d-none d-md-inline">@ViewBag.ProjectName Workspace</span>
                </div>

                <div class="d-flex align-items-center gap-4">
                    <div class="user-profile-header d-flex align-items-center gap-3">
                        <div class="user-avatar-circle" style="width: 32px; height: 32px; font-size: 0.8rem;">
                            @(User.Identity?.Name?[0].ToString().ToUpper())
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <div class="app-wrapper">
            <div id="sidebar" class="e-sidebar">
                <div class="sidebar-menu">
                    <div class="text-secondary smaller fw-bold text-uppercase px-4 mb-3" style="letter-spacing: 1px;">Navigation</div>
                    <a href="@Url.Action("Index", "Home")">
                        <i class="fas fa-home"></i> Back to Home
                    </a>
                    <a href="javascript:void(0);" onclick="onDashboardViewClick()" class="active" id="linkDashboard">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                    <a href="javascript:void(0);" onclick="onKanbanViewClick()" id="linkKanban">
                        <i class="fas fa-columns"></i> Kanban Board
                    </a>
                </div>
            </div>

            <main class="main-wrapper">
                <div class="custom-container">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <partial name="_ConfirmationDialog"></partial>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <ejs-scripts></ejs-scripts>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        let sidebarObj;

        function initSidebar() {
            if (sidebarObj) sidebarObj.destroy();
            const isMobile = window.innerWidth <= 768;
            sidebarObj = new ej.navigations.Sidebar({
                width: '260px',
                type: isMobile ? 'Over' : 'Push',
                isOpen: !isMobile,
                showBackdrop: isMobile,
                closeOnDocumentClick: isMobile,
                position: 'Left'
            });
            sidebarObj.appendTo('#sidebar');
        }

        document.addEventListener('DOMContentLoaded', function () {
            initSidebar();
            window.addEventListener('resize', initSidebar);
            document.getElementById('sidebarToggle').onclick = () => sidebarObj.toggle();
        });

        function onDashboardViewClick() {
            $('#linkKanban').removeClass('active');
            $('#linkDashboard').addClass('active');
            $('#kanbanView').hide();
            $('#workspaceContent').show();
        }

        function onKanbanViewClick() {
            $('#linkDashboard').removeClass('active');
            $('#linkKanban').addClass('active');
            loadKanbanScripts();
            $('#workspaceContent').hide();
            $('#kanbanView').show();
        }

        function loadKanbanScripts() {
            var pId = '@ViewBag.ProjectID';
            $.get('@Url.Action("GetKanbanTasks", "Kanban")', { projectId: pId }, function (tasks) {
                var kanbanObj = document.getElementById("KanbanBoard")?.ej2_instances?.[0];
                if (kanbanObj) {
                    kanbanObj.dataSource = tasks;
                }
            });
        }
    </script>

    @if (TempData["RepoNotification"] != null)
    {
        <script>ejs.notifications.ToastUtility.show('@TempData["RepoNotification"]', 'Success', 3000);</script>
    }
    @if (TempData["RepoNotificationFailed"] != null)
    {
        <script>ejs.notifications.ToastUtility.show('@TempData["RepoNotificationFailed"]', 'Error', 3000);</script>
    }
</body>
</html>