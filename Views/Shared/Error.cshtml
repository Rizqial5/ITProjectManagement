@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="mb-4 text-center py-5">
    <div class="stat-icon bg-soft-danger mx-auto mb-4" style="width: 80px; height: 80px; font-size: 2.5rem;">
        <i class="fas fa-exclamation-triangle"></i>
    </div>
    <h1 class="project-title mb-2">Oops! Something went wrong.</h1>
    <p class="text-secondary">An error occurred while processing your request. Please try again later.</p>
</div>

<div class="card-custom border-danger bg-light-danger" style="background: #fffafa;">
    <h5 class="fw-bold text-danger mb-3">Error Details</h5>
    
    @if (Model.ShowRequestId)
    {
        <div class="mb-3">
            <span class="text-secondary smaller fw-bold text-uppercase d-block mb-1">Request ID</span>
            <code class="bg-white border rounded px-3 py-2 d-inline-block text-danger">@Model.RequestId</code>
        </div>
    }

    <div class="p-3 bg-white border rounded-3 mt-4">
        <h6 class="fw-bold text-main mb-2">Development Mode</h6>
        <p class="text-secondary small mb-0" style="line-height: 1.6;">
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
        </p>
    </div>
    
    <div class="mt-4">
        <a href="/" class="btn btn-primary px-4 fw-bold" style="border-radius: 10px;">Return Dashboard</a>
    </div>
</div>
