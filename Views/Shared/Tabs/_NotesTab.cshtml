@using ProjectManagement.App.DTO.Task
@using Syncfusion.EJ2
@using Syncfusion.EJ2.RichTextEditor
@using Syncfusion.EJ2.Buttons
@using ProjectManagement.App.Extensions
@model SaveNotesDto;

@{
    var items = new object[] {
        "Bold", "Italic", "Underline", "StrikeThrough",
        "FontName", "FontSize",
        "Formats", "Alignments", "OrderedList", "UnorderedList",
        "Outdent", "Indent", "CreateLink", "Image",
        "SourceCode", "Undo", "Redo"
    };
}

<div style="padding: 16px;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="notesHtmlValue" value="" />
    @Html.HiddenFor(model => model.TaskId)
    @Html.HiddenFor(model => model.ProjectId)
    @Html.HiddenFor(model => model.NotesHtml)

    <!-- Display Mode -->
    <div id="notesDisplayMode" style="display: block;">
        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
            <div class="fw-bold text-main">
                <i class="fas fa-sticky-note me-2 text-warning"></i>
                Notes
            </div>
            <ejs-button id="btnEditNotes"
                        content="Edit Notes"
                        cssClass="e-outline"
                        iconCss="fas fa-pencil-alt"
            onclick="initializeNotes()">
            </ejs-button>
        </div>

        <div id="notesDisplayContent" class="notes-display-content">

            <p style="color: #999; font-style: italic;">No notes yet. Click Edit to add notes.</p>

            
        </div>
    </div>

    <div id="notesEditMode" style="display: none;">
        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
            <h5 class="fw-bold text-main m-0">Edit Notes</h5>
        </div>

        <div class="notes-editor-wrapper">
            <ejs-richtexteditor id="notesEditorDis"
                                height="35vh"
                                toolbarSettings="new Syncfusion.EJ2.RichTextEditor.RichTextEditorToolbarSettings
                                {
                                    Items = items
                                }"
            >
            </ejs-richtexteditor>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3 pt-2">
            <button type="button" id="btnCancelNotes" class="btn btn-light fw-bold px-4" style="border-radius: 10px; border: 1px solid var(--border-color);">
                Cancel
            </button>
            <button type="button" id="btnSaveNotes" class="btn btn-primary fw-bold px-4" style="border-radius: 10px; background-color: var(--primary-color); border: none;">
                <i class="fas fa-save me-1"></i> Save
            </button>
        </div>
    </div>

</div>

<style>
    .notes-display-content {
        background: #f8f9fa;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        min-height: 35vh;
        line-height: 1.6;
        color: #333;
        word-wrap: break-word;
    }

    .notes-display-content p {
        margin-bottom: 0.5rem;
    }

    .notes-display-content ul,
    .notes-display-content ol {
        margin-left: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .notes-display-content li {
        margin-bottom: 0.25rem;
    }

    .notes-display-content strong {
        font-weight: 600;
    }

    .notes-display-content em {
        font-style: italic;
    }

    .notes-display-content u {
        text-decoration: underline;
    }

    .notes-display-content s {
        text-decoration: line-through;
    }

    .notes-display-content a {
        color: #2563eb;
        text-decoration: none;
    }

    .notes-display-content a:hover {
        text-decoration: underline;
    }

    .notes-display-content img {
        max-width: 100%;
        height: auto;
        border-radius: 4px;
        margin: 8px 0;
    }

    /* Force RTE to participate in normal document flow */
    .notes-editor-wrapper {
        position: relative;
        width: 100%;
        margin-bottom: 16px;
    }

        /* Ensure EJ2 RTE takes full height */
        .notes-editor-wrapper .e-richtexteditor {
            display: block;
            width: 100%;
        }

    /* Prevent overlapping with action buttons */
    .notes-action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 12px;
        position: relative;
        z-index: 1;
    }

    /* Extra safety for EJ2 internal container */
    .e-richtexteditor .e-rte-container {
        box-sizing: border-box;
    }

    .gap-2 {
        gap: 8px;
    }
</style>

<script>
    var notesHtml = @Html.Raw(Json.Serialize(Model.NotesHtml)) || ''; // single source of truth

    // Jalankan langsung karena partial dimuat via AJAX
    renderDisplay();

    function initializeNotes() {
        // Set editor content

        var notesEditor = document.getElementById('notesEditorDis').ej2_instances[0];
        notesEditor.value = notesHtml || $('#NotesHtml').val();;

        toggleMode(true);
    }

    function toggleMode(isEdit) {
        document.getElementById('notesDisplayMode').style.display = isEdit ? 'none' : 'block';
        document.getElementById('notesEditMode').style.display = isEdit ? 'block' : 'none';
    }

    function renderDisplay() {
        debugger
        const display = document.getElementById('notesDisplayContent');

        if (!notesHtml || notesHtml.trim() === '') {
            display.innerHTML = `<p style="color:#999;font-style:italic">
                No notes yet. Click Edit to add notes.
            </p>`;
        } else {
            display.innerHTML = notesHtml;
        }
    }

    // SAVE
    document.getElementById('btnSaveNotes').addEventListener('click', function () {

        var notesEditor = document.getElementById('notesEditorDis').ej2_instances[0];

        notesHtml = notesEditor.value;

        $('#NotesHtml').val(notesHtml);

        renderDisplay();
        toggleMode(false);

        // 🔥 optional: save to server
        saveNotesAjax(notesHtml);
    });

    // CANCEL
    document.getElementById('btnCancelNotes').addEventListener('click', function () {

        var notesEditor = document.getElementById('notesEditorDis').ej2_instances[0];

        notesEditor.value = notesHtml; // restore
        toggleMode(false);
    });

    function saveNotesAjax(notes){
        console.log(notes);


        $.ajax({
            url: '@Url.Action("AddNotes", "Task")',
            type: 'POST',
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify({
                NotesHtml: notes,
                TaskId: $('#TaskId').val(),
                ProjectId: $('#ProjectId').val()
            }),
            success: function (result) {

                if(result.success)
                {
                    ejs.notifications.ToastUtility.show(result.message, 'Success', 3000);
                }
                else{
                    ejs.notifications.ToastUtility.show(result.message, 'Error', 3000);
                }

            },
            error: function () {
                console.error("Failed to load paged projects.");
            }
        });
    }

</script>



@Html.EJS().ScriptManager()