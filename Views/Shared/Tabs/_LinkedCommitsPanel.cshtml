@using Syncfusion.EJ2
@using Syncfusion.EJ2.Navigations
@using Syncfusion.EJ2.ProgressBar
@using Syncfusion.EJ2.Buttons
@using ProjectManagement.App.Extensions
@model ProjectManagement.App.ViewModel.TaskViewModel


@if (User.IsConnectedGithub() && Model.isConnectedRepo.Value)
{
    <!-- Linked Commits Card -->

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="card-title">
            <i class="fab fa-git-alt me-1 text-danger"></i>
            Linked Commits (@Model.TotalLinkedCommits)
        </div>
        <ejs-button id="btnAddCommit"
                    cssClass="e-outline"
                    iconCss="e-icons e-plus"
                    hx-get="@Url.Action("ShowLinkCommit", "Task", new { projectId = Model.ProjectId, isConnected = Model.isConnectedRepo })"
                    hx-target="#commitGrid"
                    hx-trigger="click"
                    hx-swap="innerHTML">
        </ejs-button>

    </div>
    <div id="listCommit" class="mt-3" style="max-height: 500px; overflow-y: auto;">
        @if (Model.Commits != null && Model.Commits.Any())
        {
            <div class="commit-list" id="commitList">
                @foreach (var commit in Model.Commits)
                {
                    <div class="commit-item-modern">
                        <div class="commit-timeline">
                            <div class="commit-sha-badge">@commit.DisplaySHA</div>
                            <div class="commit-line"></div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="commit-msg">@commit.Message</div>
                            <div class="commit-author-date">
                                <span><i class="fas fa-user-circle me-1 text-primary"></i> @commit.AuthorName</span>
                                <span><i class="fas fa-calendar-alt me-1 text-secondary"></i> @commit.CommitDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        <div class="ms-2">
                            <a href="#" class="btn btn-sm btn-outline-light text-primary border-0" title="View Commit">
                                <i class="fas fa-external-link-alt"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center p-5 text-muted">
                <i class="fas fa-code-branch fa-3x mb-3 opacity-25"></i>
                <p>No commits linked to this task yet.</p>
            </div>
        }
    </div>


}
else
{
    <div class="text-center no-repo-connected">No repo Connected</div>
}


<script>
    var btnCommit =  document.getElementById("btnAddCommit");
    var updateDateAction =  document.getElementById("updateDateAction");

    document.body.addEventListener("htmx:afterRequest", function (evt) {
        if (evt.detail.requestConfig.elt.id === "btnMarkDone") {
            location.reload();
        }
    });

    if(btnCommit)
    {
        btnCommit.addEventListener("htmx:afterOnLoad",  () => {

            // Pastikan evt.detail dan evt.detail.target aman

                openCommitDialog();

        });

    }

    if(updateDateAction)
    {
        updateDateAction.addEventListener("htmx:afterOnLoad",  () => {

            // Pastikan evt.detail dan evt.detail.target aman

                showUpdateDateDialog();

        });
    }

</script>
@Html.EJS().ScriptManager()