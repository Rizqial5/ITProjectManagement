@using Syncfusion.EJ2
@using Syncfusion.EJ2.Navigations
@using Syncfusion.EJ2.ProgressBar
@using Syncfusion.EJ2.Buttons
@using ProjectManagement.App.Extensions
@model ProjectManagement.App.ViewModel.TaskViewModel


@if (User.IsConnectedGithub() && Model.isConnectedRepo.Value)
{
    <!-- Linked Commits Card -->

    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <div class="fw-bold text-main">
            <i class="fab fa-git-alt me-2 text-danger"></i>
            Linked Commits (@Model.TotalLinkedCommits)
        </div>
        <button id="btnOpenLinkCommit"
                class="btn btn-primary fw-bold px-3 py-1 smaller"
                style="border-radius: 8px; background-color: var(--primary-color); border: none;"
                onclick="openCommitDialog()">
            <i class="fas fa-plus me-1"></i> Link Commit
        </button>
    </div>
    <div id="listCommit" class="mt-4">
        @if (Model.Commits != null && Model.Commits.Any())
        {
            <div class="commit-list" id="commitList">
                @foreach (var commit in Model.Commits)
                {
                    var commitUrl = commit.Repo != null ? $"{commit.Repo.RepoUrl.TrimEnd('/')}/commit/{commit.Sha}" : "#";
                    
                    <div class="commit-item-modern">
                        <div class="commit-timeline">
                            <div class="commit-sha-badge">@commit.DisplaySHA</div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="commit-msg">@commit.Message</div>
                            <div class="commit-author-date">
                                <span><i class="fas fa-user-circle me-1 text-primary opacity-75"></i> @commit.AuthorName</span>
                                <span class="text-light">|</span>
                                <span><i class="fas fa-calendar-alt me-1 text-secondary opacity-75"></i> @commit.CommitDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        <div class="ms-2 pt-1">
                            @if (commitUrl != "#")
                            {
                                <a href="@commitUrl" target="_blank" class="btn btn-sm btn-link p-0 text-primary" title="View on GitHub">
                                    <i class="fas fa-external-link-alt"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="no-repo-connected text-center py-5">
                <i class="fas fa-code-branch fa-3x mb-3 opacity-20"></i>
                <p class="m-0">No commits linked to this task yet.</p>
                <p class="smaller text-muted mt-1">Use the "Link Commit" button to add related work.</p>
            </div>
        }
    </div>


}
else
{
    <div class="text-center no-repo-connected">No repo Connected</div>
}


@Html.EJS().ScriptManager()