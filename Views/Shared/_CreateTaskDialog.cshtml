@using ProjectManagement.App.DTO
@using ProjectManagement.App.DTO.Task
@model CreateTaskDto

@{
    var dataDropDown = new List<DropdownItem>()
    {
        new() {value = 0.ToString() , text = "To Do" },
        new() {value = 1.ToString() , text = "Progress" },
        new() {value = 2.ToString() , text = "Done" },
    };

    var header = !string.IsNullOrWhiteSpace(Model.ProjectTitle) ? $"Add Task For {Model.ProjectTitle}" : "Add Task";
}

<ejs-dialog id="createTaskDialog" header="@header"
            width="40%" visible="false" showCloseIcon="true" isModal="true"
            target="body">
            <e-content-template>
                <form asp-action="AddTask" id="createTaskForm" asp-controller="Task" method="post" class="p-2">
                    @Html.HiddenFor(i=> i.ProjectID)
                    <div class="mb-3">
                        <label asp-for="Title" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
                        <ejs-textbox id="TaskTitle" ejs-for="Title" cssClass="e-outline"></ejs-textbox>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
                        <ejs-textbox id="TaskDescription" ejs-for="Description" cssClass="e-outline"></ejs-textbox>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
                        <ejs-dropdownlist id="TaskStatus" dataSource="@dataDropDown" ejs-for="Status" cssClass="e-outline"></ejs-dropdownlist>
                    </div>

                    <div class="mb-4">
                        <label asp-for="TargetDate" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
                        <ejs-datepicker id="TaskTargetDate" ejs-for="TargetDate" format="yyyy-MM-dd" cssClass="e-outline"></ejs-datepicker>
                    </div>

                    <div class="text-end pt-3 border-top">
                        <button type="submit" id="btnTaskSubmit" class="btn btn-primary fw-bold px-4 py-2" style="border-radius: 10px; background-color: var(--primary-color); border: none;">Add Task</button>
                    </div>
                </form>
            </e-content-template>
</ejs-dialog>

<script>

    function showCreateTaskDialog() {
        var dialog = document.getElementById("createTaskDialog").ej2_instances[0];

        dialog.show();
    }


    function getRulesFromAnnotations(field) {
        var input = document.querySelector('[name="' + field + '"]');
        var rules = {};

        if (!input) return rules;

        // cek required
        if (input.hasAttribute('data-val-required')) {
            rules['required'] = true;
        }

        // cek min length
        if (input.hasAttribute('data-val-length-min')) {
            rules['minLength'] = parseInt(input.getAttribute('data-val-length-min'));
        }

        // cek max length
        if (input.hasAttribute('data-val-length-max')) {
            rules['maxLength'] = parseInt(input.getAttribute('data-val-length-max'));
        }

        return rules;
    }

    var options = {
        rules: {
            'Title': getRulesFromAnnotations('Title'),
            'Description': getRulesFromAnnotations('Description')
        },
    };

    $('#createTaskForm').on('submit', function (e) {
        e.preventDefault();

        var form = $(this);



        var formData = form.serialize();
        var formObj = initFormValidation(this.id)

        if (!formObj.validate()) {
            e.preventDefault();
            return false;
        }

        $.ajax({
            type: 'POST',
            url: form.attr('action'),
            data: formData,
            success: function (response, status, xhr) {
                if (response.success == false) {
                    location.reload()


                } else {
                    // Sukses, tutup dialog & reload halaman
                    var dialog = $('#createTaskDialog')[0].ej2_instances[0];
                    dialog.hide();
                    location.reload();
                }
            },
            error: function () {
                alert("Terjadi kesalahan saat menyimpan.");
            }
        });
    });
</script>


