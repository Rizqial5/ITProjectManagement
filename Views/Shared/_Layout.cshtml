<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectManagement.App</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/ProjectManagement.App.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ej2/material.css" asp-append-version="true" />
    <script src="https://cdn.syncfusion.com/ej2/31.2.12/dist/ej2.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</head>
<body>
    <div id="dialogTarget"></div>
    <partial name="_ConfirmationDialog"></partial>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow fixed-top">
        <div class="container-fluid">
            <button id="sidebarToggle" class="btn btn-outline-primary btn-sm me-2">
                <i class="fas fa-bars"></i>
            </button>
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">ProjectManagement</a>

            <div class="collapse navbar-collapse justify-content-end">
                <ul class="navbar-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item position-relative">
                            <a class="nav-link text-dark" href="#">
                                <i class="fas fa-bell"></i>
                                <span class="badge bg-danger rounded-pill notification-badge">3</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <span class="nav-link text-dark">Hey, @User.Identity.Name!</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Wrapper (sidebar + content) -->
    <div class="app-wrapper">
        <!-- Sidebar -->
        <div id="sidebar" class="e-sidebar">
            <div class="sidebar-menu">
                <a href="@Url.Action("Index", "Home")"><i class="fas fa-home me-2"></i> Home</a>
                <a href="#"><i class="fas fa-chart-line me-2"></i> Dashboard</a>
                <a href="@Url.Action("Page", "Projects")"><i class="fas fa-columns me-2"></i> Projects</a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-wrapper">
            <div class="container-fluid custom-container mt-3">
                <main role="main" id="main-content">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - ProjectManagement.App -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/project.js" asp-append-version="true"></script>
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/_hyperscript.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["RepoNotification"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                ejs.notifications.ToastUtility.show('@TempData["RepoNotification"]', 'Success', 3000);
            });
        </script>
    }

    @if (TempData["RepoNotificationFailed"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                ejs.notifications.ToastUtility.show('@TempData["RepoNotificationFailed"]', 'Error', 3000);
            });
        </script>
    }

    <script>
        let sidebarObj;

        function initSidebar() {
            if (sidebarObj) {
                sidebarObj.destroy();
            }

            sidebarObj = new ej.navigations.Sidebar({
                width: '250px',
                type: 'Over',
                isOpen: false,
                showBackdrop: true,
                closeOnDocumentClick: false, // 🔥 IMPORTANT
                position: 'Left'
            });

            sidebarObj.appendTo('#sidebar');
        }

        document.addEventListener('DOMContentLoaded', function () {
            initSidebar();

            const toggleBtn = document.getElementById('sidebarToggle');

            toggleBtn.addEventListener('click', function (e) {
                e.preventDefault();

                sidebarObj.isOpen
                    ? sidebarObj.hide()
                    : sidebarObj.show();
            });

            document.querySelectorAll('.sidebar-menu a').forEach(link => {
                link.addEventListener('click', () => sidebarObj.hide());
            });
        });
    </script>

    <ejs-scripts></ejs-scripts>
</body>
</html>
