<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectManagement.App</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/ProjectManagement.App.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ej2/material.css" asp-append-version="true" />
    <script src="https://cdn.syncfusion.com/ej2/31.2.12/dist/ej2.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</head>
<body>
    <div id="app-root">
        <div id="dialogTarget"></div>
        <partial name="_ConfirmationDialog"></partial>

        <!-- Navbar -->
        <nav class="navbar navbar-expand-sm">
            <div class="container-fluid p-0">
                <div class="d-flex align-items-center">
                    <button id="sidebarToggle" class="btn me-3">
                        <i class="fas fa-bars"></i>
                    </button>
                    <a class="navbar-brand" href="@Url.Action("Index", "Home")">ProjectManagement</a>
                </div>

                <div class="collapse navbar-collapse justify-content-end">
                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item position-relative me-3">
                                <a class="nav-link text-dark p-0" href="#">
                                    <i class="fas fa-bell fs-5"></i>
                                    <span class="badge bg-danger rounded-pill notification-badge">3</span>
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <span class="fw-bold text-secondary">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Wrapper (sidebar + content) -->
        <div class="app-wrapper">
            <!-- Sidebar -->
            <div id="sidebar" class="e-sidebar">
                <div class="sidebar-menu">
                    <a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="fas fa-home"></i> Home
                    </a>
                    <a href="#">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>
                    <a href="@Url.Action("Page", "Projects")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")">
                        <i class="fas fa-columns"></i> Projects
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="main-wrapper">
                <div class="custom-container">
                    <main role="main" id="main-content">
                        @RenderBody()
                    </main>
                </div>
                
                <footer class="mt-auto">
                    <div>
                        &copy; 2024 - ProjectManagement.App -
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy</a>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/project.js" asp-append-version="true"></script>
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/_hyperscript.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        let sidebarObj;

        function initSidebar() {
            if (sidebarObj) {
                sidebarObj.destroy();
            }

            const isMobile = window.innerWidth <= 768;

            sidebarObj = new ej.navigations.Sidebar({
                width: '260px',
                type: isMobile ? 'Over' : 'Push',
                isOpen: !isMobile,
                showBackdrop: isMobile,
                closeOnDocumentClick: isMobile,
                position: 'Left'
            });

            sidebarObj.appendTo('#sidebar');
        }

        document.addEventListener('DOMContentLoaded', function () {
            initSidebar();

            window.addEventListener('resize', function() {
                const isMobile = window.innerWidth <= 768;
                if (sidebarObj) {
                    sidebarObj.type = isMobile ? 'Over' : 'Push';
                    sidebarObj.showBackdrop = isMobile;
                    sidebarObj.closeOnDocumentClick = isMobile;
                }
            });

            const toggleBtn = document.getElementById('sidebarToggle');
            toggleBtn.addEventListener('click', function (e) {
                e.preventDefault();
                sidebarObj.toggle();
            });

            // Handle active links or other sidebar interactions
        });
    </script>

    <ejs-scripts></ejs-scripts>
</body>
</html>
