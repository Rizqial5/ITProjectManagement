@using ProjectManagement.App.Extensions
@using ProjectManagement.App.DTO.Project
@using System.Security.Claims
@inject ProjectManagement.App.Repository.Interface.IWorkspaceRepository WorkspaceRepository
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CommitLink</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/ProjectManagement.App.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ej2/material.css" asp-append-version="true" />
    <script src="https://cdn.syncfusion.com/ej2/31.2.12/dist/ej2.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</head>
<body>
    <div id="app-root">
        <div id="dialogTarget"></div>
        <partial name="_ConfirmationDialog"></partial>

        <!-- Navbar -->
        @if (ViewBag.HideNavAndSidebar != true)
        {
            <nav class="navbar navbar-expand-sm">
                <div class="container-fluid p-0 d-flex justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <button id="sidebarToggle" class="btn">
                            <i class="fas fa-bars"></i>
                        </button>
                        <a class="navbar-brand d-none d-md-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                            <div class="bg-primary rounded-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px;">
                                <i class="fas fa-link text-white fs-6"></i>
                            </div>
                            <div class="d-flex flex-column line-height-1">
                                <span class="fw-800 text-main tracking-tight" style="font-size: 1.25rem; letter-spacing: -0.5px;">Commit<span class="text-primary">Link</span></span>
                            </div>
                        </a>

                        @if (User.Identity?.IsAuthenticated == true && !string.IsNullOrEmpty(User.GetWorkspaceName()))
                        {
                            var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                            var workspaces = userId != null
                                ? await WorkspaceRepository.GetUserWorkspacesAsync(userId)
                                : Enumerable.Empty<ProjectManagement.App.Models.Workspace.WorkspaceMember>();
                            var currentWorkspaceId = User.GetWorkspaceId();

                            <div class="dropdown ms-2 d-none d-md-block">
                                <button class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent px-2 py-1" 
                                        type="button" id="workspaceDropdown" data-bs-toggle="dropdown" aria-expanded="false" 
                                        style="border-radius: 8px; color: #4b5563; font-weight: 600; font-size: 0.85rem; box-shadow: none;">
                                    <i class="fas fa-building text-primary small"></i>
                                    <span>@User.GetWorkspaceName()</span>
                                </button>
                                <ul class="dropdown-menu shadow-elegant border-0 py-2 mt-1" aria-labelledby="workspaceDropdown" 
                                    style="border-radius: 12px; min-width: 220px; font-size: 0.85rem; border: 1px solid #f1f5f9;">
                                    <li class="dropdown-header text-uppercase tracking-wider fw-bold text-secondary pb-2" style="font-size: 0.7rem; color: #94a3b8 !important;">Switch Workspace</li>
                                    @foreach (var wm in workspaces)
                                    {
                                        var isActive = wm.WorkspaceId == currentWorkspaceId;
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center justify-content-between py-2 px-3 @(isActive ? "active bg-light text-primary fw-bold" : "text-main")" 
                                               href="#" onclick="globalSwitchWorkspace(@wm.WorkspaceId); return false;">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-folder small @(isActive ? "text-primary" : "text-secondary")"></i>
                                                    <span>@wm.Workspace?.Name</span>
                                                </div>
                                                @if (isActive)
                                                {
                                                    <i class="fas fa-check text-primary small"></i>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                        
                        <div class="search-container d-none d-lg-block ms-4">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0 border-0 ps-0 text-secondary">
                                    <i class="fas fa-search"></i>
                                </span>
                                <input type="text" class="form-control border-0 bg-transparent ps-2" placeholder="Search anything..." style="box-shadow: none; width: 300px;">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-4">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="d-flex gap-2">
                                @if (!User.IsConnectedGithub())
                                {
                                    <div class="d-none d-md-inline-block">
                                        <ejs-button id="btnConnectGithubGlobal"
                                                    cssClass="e-outline px-3 py-2"
                                                    content="Connect GitHub"
                                                    iconCss="fab fa-github"
                                                    onclick="window.location.href='@Url.Action("Connect", "GithubAuth")'">
                                        </ejs-button>
                                    </div>
                                }

                                <div class="d-none d-md-inline-block">
                                    <ejs-button id="btnNewProjectGlobal"
                                                cssClass="e-primary px-4 py-2"
                                                content="New Project"
                                                iconCss="e-icons e-plus"
                                                onclick="createProject()">
                                    </ejs-button>
                                </div>
                            </div>

                            <div class="nav-notifications position-relative dropdown">
                                <a class="text-secondary dropdown-toggle" href="#" role="button" id="notificationBell" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-bell fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger p-1 border border-light" style="font-size: 0.5rem; display: none; width: 1.25rem; height: 1.25rem; align-items: center; justify-content: center;" id="notificationCount"></span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow-elegant" aria-labelledby="notificationBell" style="border-radius: 12px; min-width: 350px; max-width: 350px; border: 1px solid #f1f5f9;">
                                    <div class="px-3 pt-2 pb-2 d-flex justify-content-between align-items-center">
                                        <h6 class="dropdown-header fw-bold text-main p-0">Notifications</h6>
                                        <a class="text-primary smaller fw-bold text-decoration-none" href="#" id="markAllAsReadBtn">Mark all as read</a>
                                    </div>
                                    <div id="notificationDropdownContent" style="max-height: 400px; overflow-y: auto;">
                                        <div class="dropdown-item text-center text-secondary py-4">Loading...</div>
                                    </div>
                                    <div class="dropdown-divider m-0"></div>
                                    <a class="dropdown-item text-center text-primary fw-bold py-2" href="#">View All Notifications</a>
                                </div>
                            </div>

                            <div class="user-profile-header d-flex align-items-center gap-3 ps-3 border-start">
                                <div class="text-end d-none d-sm-block">
                                    <div class="fw-bold small text-main">@User.Identity.Name</div>
                                </div>
                                <div class="user-avatar-circle">
                                    @(User.Identity.Name?[0].ToString().ToUpper())
                                </div>
                                
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-link text-secondary p-0">
                                        <i class="fas fa-sign-out-alt"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-3">
                                <a class="btn btn-link text-dark text-decoration-none fw-600" asp-controller="Account" asp-action="Login">Login</a>
                                <a class="btn btn-primary px-4" asp-controller="Account" asp-action="Register">Register</a>
                            </div>
                        }
                    </div>
                </div>
            </nav>
        }

        <!-- Wrapper (sidebar + content) -->
        <div class="app-wrapper">
            <!-- Sidebar -->
            @if (ViewBag.HideNavAndSidebar != true)
            {
                <div id="sidebar" class="e-sidebar">
                    <div class="sidebar-menu">
                        <a href="@Url.Action("Index", "Home")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                        <a href="@Url.Action("Page", "Projects")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")">
                            <i class="fas fa-columns"></i> Projects
                        </a>
                        <a href="@Url.Action("Index", "WorkspaceSettings")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "WorkspaceSettings" ? "active" : "")">
                            <i class="fas fa-cog"></i> Settings
                        </a>
                    </div>
                </div>
            }

            <!-- Main Content -->
            <div class="main-wrapper @(ViewBag.HideNavAndSidebar == true ? "p-0" : "")">
                <div class="custom-container d-flex flex-column">
                    <main role="main" id="main-content" class="@(ViewBag.HideNavAndSidebar == true ? "flex-grow-1 d-flex flex-column" : "")">
                        @RenderBody()
                    </main>
                </div>
                
                @if (ViewBag.HideNavAndSidebar != true)
                {
                    <footer class="mt-auto">
                        <div class="footer-content">
                            <div class="footer-copyright">
                                &copy; 2024 CommitLink <span class="text-light ms-2">|</span> <span class="ms-2">v1.0.4</span>
                            </div>
                            <div class="footer-links">
                                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                                <a href="#">Terms</a>
                                <a href="#">Support</a>
                            </div>
                        </div>
                    </footer>
                }
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/project.js" asp-append-version="true"></script>
    <script src="~/js/notification.js" asp-append-version="true"></script>
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/_hyperscript.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        let sidebarObj;

        function initSidebar() {
            const sidebarElement = document.getElementById('sidebar');
            if (!sidebarElement) return;

            if (sidebarObj) {
                sidebarObj.destroy();
            }

            const isMobile = window.innerWidth <= 768;

            sidebarObj = new ej.navigations.Sidebar({
                width: '260px',
                type: isMobile ? 'Over' : 'Push',
                isOpen: !isMobile,
                showBackdrop: isMobile,
                closeOnDocumentClick: isMobile,
                position: 'Left'
            });

            sidebarObj.appendTo('#sidebar');
        }

        document.addEventListener('DOMContentLoaded', function () {
            initSidebar();

            window.addEventListener('resize', function() {
                const isMobile = window.innerWidth <= 768;
                if (sidebarObj) {
                    sidebarObj.type = isMobile ? 'Over' : 'Push';
                    sidebarObj.showBackdrop = isMobile;
                    sidebarObj.closeOnDocumentClick = isMobile;
                }
            });

            const toggleBtn = document.getElementById('sidebarToggle');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (sidebarObj) {
                        sidebarObj.toggle();
                        
                        // Dispatch resize events smoothly during transition to update progress bar width
                        let count = 0;
                        const interval = setInterval(function() {
                            window.dispatchEvent(new Event('resize'));
                            count++;
                            if (count >= 15) {
                                clearInterval(interval);
                            }
                        }, 25);
                    }
                });
            }

            // Handle active links or other sidebar interactions
        });
    </script>

    <ejs-toast id="toast_global"></ejs-toast>

    <script>
        function showGlobalNotification(message, type) {
            setTimeout(function() {
                if (window.ejs && ejs.notifications && ejs.notifications.ToastUtility) {
                    ejs.notifications.ToastUtility.show(message, type || 'Info', 3000);
                }
            }, 500);
        }

        document.addEventListener("DOMContentLoaded", function () {
            @if (TempData["RepoNotification"] != null)
            {
                <text>showGlobalNotification('@TempData["RepoNotification"]', 'Success');</text>
            }
            @if (TempData["RepoNotificationFailed"] != null)
            {
                <text>showGlobalNotification('@TempData["RepoNotificationFailed"]', 'Error');</text>
            }
        });
    </script>

    <form id="globalSwitchWorkspaceForm" action="/WorkspaceSettings/SwitchWorkspace" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="workspaceId" id="globalSwitchWorkspaceId" />
    </form>

    <script>
        function globalSwitchWorkspace(workspaceId) {
            var form = document.getElementById('globalSwitchWorkspaceForm');
            document.getElementById('globalSwitchWorkspaceId').value = workspaceId;
            var token = form.querySelector('input[name="__RequestVerificationToken"]').value;

            $.ajax({
                type: 'POST',
                url: form.action,
                data: {
                    workspaceId: workspaceId,
                    __RequestVerificationToken: token
                },
                success: function (response) {
                    if (response.success) {
                        window.location.href = response.redirectUrl;
                    } else {
                        if (window.ejs && ejs.notifications && ejs.notifications.ToastUtility) {
                            ejs.notifications.ToastUtility.show(response.message || "Failed to switch workspace.", 'Error', 3000);
                        } else {
                            alert(response.message || "Failed to switch workspace.");
                        }
                    }
                },
                error: function () {
                    if (window.ejs && ejs.notifications && ejs.notifications.ToastUtility) {
                        ejs.notifications.ToastUtility.show("An error occurred while switching workspace.", 'Error', 3000);
                    } else {
                        alert("An error occurred while switching workspace.");
                    }
                }
            });
        }
    </script>

    <partial name="_CreateProjectModal" />
    <ejs-scripts></ejs-scripts>
</body>
</html>
