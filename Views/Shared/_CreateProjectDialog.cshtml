@using ProjectManagement.App.DTO.Project
@model CreateProjectDto


<form asp-action="CreateProject" id="createForm" asp-controller="Home" method="post" class="p-2">

	<div class="mb-3">
		<label asp-for="Title" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
		<ejs-textbox ejs-for="Title" cssClass="e-outline"></ejs-textbox>
		@* <span asp-validation-for="Title"></span> *@
	</div>

	<div class="mb-3">
		<label asp-for="Description" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
        <ejs-textbox ejs-for="Description" cssClass="e-outline"></ejs-textbox>
		@* <span asp-validation-for="Description"></span> *@
	</div>

    <div class="mb-4">
        <label asp-for="EndDate" class="text-secondary smaller fw-bold text-uppercase mb-2 d-block" style="letter-spacing: 0.5px;"></label>
        <ejs-datepicker id="EndDate" ejs-for="EndDate" name="EndDate" format="yyyy-MM-dd" cssClass="e-outline"></ejs-datepicker>
        <span asp-validation-for="EndDate" class="text-danger smaller"></span>
    </div>

	<div class="text-end pt-3 border-top" >
		<button type="submit" id="submit" class="btn btn-primary fw-bold px-4 py-2" style="border-radius: 10px; background-color: var(--primary-color); border: none;">Add Project</button>
	</div>
</form>

<script>
    function getRulesFromAnnotations(field) {
        var input = document.querySelector('[name="' + field + '"]');
        var rules = {};

        if (!input) return rules;

        // cek required
        if (input.hasAttribute('data-val-required')) {
            rules['required'] = true;
        }

        // cek min length
        if (input.hasAttribute('data-val-length-min')) {
            rules['minLength'] = parseInt(input.getAttribute('data-val-length-min'));
        }

        // cek max length
        if (input.hasAttribute('data-val-length-max')) {
            rules['maxLength'] = parseInt(input.getAttribute('data-val-length-max'));
        }

        return rules;
    }

    var options = {
        rules: {
            'Title': getRulesFromAnnotations('Title'),
            'Description': getRulesFromAnnotations('Description')
        },
    };

    $('#createForm').on('submit', function (e) {
        e.preventDefault();

        var form = $(this);



        var formData = form.serialize();
        var formObj = initFormValidation(this.id)

        if (!formObj.validate()) {
            e.preventDefault();
            return false;
        }
        $.ajax({
            type: 'POST',
            url: form.attr('action'),
            data: formData,
            success: function (response, status, xhr) {
                if (response.success == false) {
                    location.reload()


                } else {
                    // Sukses, tutup dialog & reload halaman
                    var dialog = $('#createProjectDialog')[0].ej2_instances[0];
                    dialog.hide();
                    location.reload();
                }
            },
            error: function () {
                alert("Terjadi kesalahan saat menyimpan.");
            }
        });
    });
</script>


